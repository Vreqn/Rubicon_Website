---
/**
 * Blog post shell — light surface (long-form reading happens on Bone).
 */
import BaseLayout from './BaseLayout.astro';
import Eyebrow from '../components/Eyebrow.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
}

const { title, description, pubDate, updatedDate } = Astro.props;

const fmt = (d: Date) =>
  d.toLocaleDateString('en-CA', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout
  title={`Rubicon Workflows | ${title}`}
  description={description}
  surface="light"
  ogType="article"
>
  <article class="post">
    <div class="container">
      <header class="post__header">
        <Eyebrow>Blog</Eyebrow>
        <h1 class="post__title">{title}</h1>
        <p class="post__meta">
          <time datetime={pubDate.toISOString().slice(0, 10)}>{fmt(pubDate)}</time>
          {updatedDate && (
            <>
              {' '}&middot; updated{' '}
              <time datetime={updatedDate.toISOString().slice(0, 10)}>{fmt(updatedDate)}</time>
            </>
          )}
        </p>
      </header>

      <div class="prose">
        <slot />
      </div>

      <p class="post__back">
        <a href="/blog/">&larr; All posts</a>
      </p>
    </div>
  </article>
</BaseLayout>

<style>
  .post {
    padding-block: var(--section-pad);
  }

  .post__header {
    max-width: var(--container-prose);
    margin-bottom: var(--space-12);
  }

  .post__title {
    margin-top: var(--space-3);
  }

  .post__meta {
    margin-top: var(--space-3);
    font-size: var(--text-caption);
    line-height: var(--lh-caption);
    color: var(--muted);
  }

  .post__back {
    margin-top: var(--space-16);
  }

  .post__back a {
    color: var(--accent);
    text-decoration: none;
  }

  .post__back a:hover {
    text-decoration: underline;
  }
</style>
