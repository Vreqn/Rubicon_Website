---
/**
 * Mono kicker label above sections, e.g. "~ OUR APPROACH".
 * Color is var(--accent-text): Sage on dark (brand spec), Forest on light,
 * Bone on forest — every pairing passes AA for readable text. Raw Sage is
 * NOT used on Bone/Forest surfaces (~2.5:1 / ~3.4:1, decorative only).
 */
interface Props {
  tilde?: boolean;
  class?: string;
}

const { tilde = true, class: className } = Astro.props;
---

<span class:list={['eyebrow', className]}>{tilde && <span aria-hidden="true">~&nbsp;</span>}<slot /></span>

<style>
  .eyebrow {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--text-eyebrow);
    line-height: var(--lh-eyebrow);
    letter-spacing: var(--track-eyebrow);
    text-transform: uppercase;
    color: var(--accent-text, var(--sage));
  }
</style>
