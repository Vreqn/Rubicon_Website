---
/**
 * Brand icon set — mixed-weight rounded: 2px stroke outer shapes, 1.5px inner
 * details, round caps/joins, no fills. One icon, one color (Sage by default
 * via `color`). `feature` wraps the icon in the 10px rounded square container
 * filled Sage @ 13% (brand feature variant).
 */
interface Props {
  name: keyof typeof icons;
  size?: number;
  feature?: boolean;
  /** Accessible label; omit for decorative icons (default, aria-hidden). */
  label?: string;
  class?: string;
}

const icons = {
  /* gauge — operational efficiency */
  gauge: `<path d="M4 14a8 8 0 1 1 16 0" stroke-width="2"/><path d="M12 14l3.5-4" stroke-width="1.5"/><path d="M4.5 14H6M18 14h1.5" stroke-width="1.5"/>`,
  /* shield with check — error reduction */
  'shield-check': `<path d="M12 3l7 2.8v5.4c0 4.3-2.9 7.3-7 8.8-4.1-1.5-7-4.5-7-8.8V5.8z" stroke-width="2"/><path d="M9 12l2 2 4-4.5" stroke-width="1.5"/>`,
  /* ascending steps — incremental and embedded */
  steps: `<path d="M3 19h4.5v-4.5H12V10h4.5V5.5H21" stroke-width="2"/><path d="M18.5 8l2.5-2.5L18.5 3" stroke-width="1.5"/>`,
  /* person with plus — augmentation, not replacement */
  'user-plus': `<circle cx="10" cy="8" r="3.5" stroke-width="2"/><path d="M4 20c0-3.3 2.7-5.5 6-5.5s6 2.2 6 5.5" stroke-width="2"/><path d="M18.5 7.5v5M16 10h5" stroke-width="1.5"/>`,
  /* arrow right */
  'arrow-right': `<path d="M4 12h16M14 6l6 6-6 6" stroke-width="2"/>`,
  /* mail */
  mail: `<rect x="3" y="5.5" width="18" height="13" rx="2.5" stroke-width="2"/><path d="M4.5 8l7.5 5 7.5-5" stroke-width="1.5"/>`,
  /* bar chart in frame — automated reporting */
  chart: `<rect x="3" y="3" width="18" height="18" rx="2.5" stroke-width="2"/><path d="M7.5 16v-3.5M12 16V8.5M16.5 16v-6" stroke-width="1.5"/>`,
  /* two connected nodes — connecting systems */
  nodes: `<circle cx="6" cy="6" r="3" stroke-width="2"/><circle cx="18" cy="18" r="3" stroke-width="2"/><path d="M8.2 8.2l3.3 3.3M15.8 15.8l-3.3-3.3" stroke-width="1.5"/><path d="M12.5 11.5l-1 1" stroke-width="1.5"/>`,
  /* arrow into tray — data entry automation */
  intake: `<path d="M3 14v3.5A2.5 2.5 0 0 0 5.5 20h13a2.5 2.5 0 0 0 2.5-2.5V14" stroke-width="2"/><path d="M12 4v9M8.5 10l3.5 3.5L15.5 10" stroke-width="1.5"/>`,
  /* document with lines — document processing */
  document: `<path d="M6 3h8l4 4v11.5a2.5 2.5 0 0 1-2.5 2.5h-7A2.5 2.5 0 0 1 6 18.5V3z" stroke-width="2"/><path d="M14 3v4h4M9.5 12h5M9.5 15.5h5" stroke-width="1.5"/>`,
  /* circle with check — verification tools */
  'check-circle': `<circle cx="12" cy="12" r="9" stroke-width="2"/><path d="M8.5 12.2l2.4 2.4 4.6-5" stroke-width="1.5"/>`,
  /* magnifier — find the bottleneck (2026-06 design port) */
  search: `<circle cx="11" cy="11" r="6.5" stroke-width="2"/><path d="M16 16l5 5" stroke-width="1.5"/>`,
  /* clock — hand back the hours (2026-06 design port) */
  clock: `<circle cx="12" cy="12" r="8.5" stroke-width="2"/><path d="M12 7.4V12l3 2" stroke-width="1.5"/>`,
  /* two arcs cycling — process automation (2026-06 design port) */
  refresh: `<path d="M4.5 12a7.5 7.5 0 0 1 12.7-5.4M19.5 12a7.5 7.5 0 0 1-12.7 5.4" stroke-width="2"/><path d="M17.5 3.2v3.6h-3.6M6.5 20.8v-3.6h3.6" stroke-width="1.5"/>`,
  /* crosshair circle — automate the routine, not the judgment (2026-06) */
  target: `<circle cx="12" cy="12" r="4" stroke-width="2"/><path d="M12 3v3M12 18v3M3 12h3M18 12h3" stroke-width="1.5"/>`,
  /* toolbox with plus — fit the work you already have (2026-06) */
  toolbox: `<rect x="3.5" y="6" width="17" height="12" rx="2" stroke-width="2"/><path d="M8 6V4.5h8V6M12 10v4M10 12h4" stroke-width="1.5"/>`,
  /* flag with marker — one bottleneck at a time (2026-06) */
  flag: `<path d="M4 18V6" stroke-width="2"/><path d="M4 7h9a3 3 0 0 1 0 6H4" stroke-width="2"/><circle cx="17.5" cy="10" r="1.4" fill="currentColor" stroke="none"/>`,
} as const;

const { name, size = 24, feature = false, label, class: className } = Astro.props;
---

{
  feature ? (
    <span class:list={['icon-feature', className]}>
      <svg
        width={size}
        height={size}
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden={label ? undefined : 'true'}
        aria-label={label}
        role={label ? 'img' : undefined}
        set:html={icons[name]}
      />
    </span>
  ) : (
    <svg
      class={className}
      width={size}
      height={size}
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden={label ? undefined : 'true'}
      aria-label={label}
      role={label ? 'img' : undefined}
      set:html={icons[name]}
    />
  )
}

<style>
  svg {
    color: var(--accent, var(--sage));
    flex-shrink: 0;
  }

  .icon-feature {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-3);
    border-radius: var(--radius-md);
    background-color: var(--sage-tint-13);
  }
</style>
