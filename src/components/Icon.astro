---
/**
 * Brand icon set — mixed-weight rounded: 2px stroke outer shapes, 1.5px inner
 * details, round caps/joins, no fills. One icon, one color (Sage by default
 * via `color`). `feature` wraps the icon in the 10px rounded square container
 * filled Sage @ 13% (brand feature variant).
 */
interface Props {
  name: keyof typeof icons;
  size?: number;
  feature?: boolean;
  /** Accessible label; omit for decorative icons (default, aria-hidden). */
  label?: string;
  class?: string;
}

const icons = {
  /* gauge — operational efficiency */
  gauge: `<path d="M4 14a8 8 0 1 1 16 0" stroke-width="2"/><path d="M12 14l3.5-4" stroke-width="1.5"/><path d="M4.5 14H6M18 14h1.5" stroke-width="1.5"/>`,
  /* shield with check — error reduction */
  'shield-check': `<path d="M12 3l7 2.8v5.4c0 4.3-2.9 7.3-7 8.8-4.1-1.5-7-4.5-7-8.8V5.8z" stroke-width="2"/><path d="M9 12l2 2 4-4.5" stroke-width="1.5"/>`,
  /* ascending steps — incremental and embedded */
  steps: `<path d="M3 19h4.5v-4.5H12V10h4.5V5.5H21" stroke-width="2"/><path d="M18.5 8l2.5-2.5L18.5 3" stroke-width="1.5"/>`,
  /* person with plus — augmentation, not replacement */
  'user-plus': `<circle cx="10" cy="8" r="3.5" stroke-width="2"/><path d="M4 20c0-3.3 2.7-5.5 6-5.5s6 2.2 6 5.5" stroke-width="2"/><path d="M18.5 7.5v5M16 10h5" stroke-width="1.5"/>`,
  /* arrow right */
  'arrow-right': `<path d="M4 12h16M14 6l6 6-6 6" stroke-width="2"/>`,
  /* mail */
  mail: `<rect x="3" y="5.5" width="18" height="13" rx="2.5" stroke-width="2"/><path d="M4.5 8l7.5 5 7.5-5" stroke-width="1.5"/>`,
} as const;

const { name, size = 24, feature = false, label, class: className } = Astro.props;
---

{
  feature ? (
    <span class:list={['icon-feature', className]}>
      <svg
        width={size}
        height={size}
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden={label ? undefined : 'true'}
        aria-label={label}
        role={label ? 'img' : undefined}
        set:html={icons[name]}
      />
    </span>
  ) : (
    <svg
      class={className}
      width={size}
      height={size}
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden={label ? undefined : 'true'}
      aria-label={label}
      role={label ? 'img' : undefined}
      set:html={icons[name]}
    />
  )
}

<style>
  svg {
    color: var(--accent, var(--sage));
    flex-shrink: 0;
  }

  .icon-feature {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-3);
    border-radius: var(--radius-md);
    background-color: var(--sage-tint-13);
  }
</style>
