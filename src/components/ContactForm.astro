---
/**
 * Contact form — native POST to Formspree, zero JS.
 * Endpoint comes from PUBLIC_FORMSPREE_ENDPOINT (Vercel env / local .env).
 * Until the endpoint exists the form renders DISABLED with a visible TODO —
 * it must not pretend to work (Content-Decisions.md #14).
 *
 * 2026-06 design port: editorial underline fields (mono labels, a Forest
 * rule that draws in on focus). The comp's mock JS thanks-state is NOT
 * ported — the real flow redirects to /contact/thanks/.
 */
import Todo from './Todo.astro';

const endpoint = import.meta.env.PUBLIC_FORMSPREE_ENDPOINT as string | undefined;
const live = Boolean(endpoint);
---

<form
  class="contact-form"
  method="POST"
  action={live ? endpoint : '#'}
  aria-describedby={live ? undefined : 'form-status'}
>
  {
    !live && (
      <p id="form-status" class="contact-form__notice">
        <Todo label="form endpoint not configured — submissions disabled; email works today" />
      </p>
    )
  }

  <div class="contact-form__row">
    <div class="contact-form__field">
      <label for="cf-name">Name</label>
      <input id="cf-name" name="name" type="text" autocomplete="name" required />
    </div>
    <div class="contact-form__field">
      <label for="cf-email">Work email</label>
      <input id="cf-email" name="email" type="email" autocomplete="email" required />
    </div>
  </div>

  <div class="contact-form__field">
    <label for="cf-company">Company <span class="opt">&mdash; optional</span></label>
    <input id="cf-company" name="company" type="text" autocomplete="organization" />
  </div>

  <div class="contact-form__field">
    <label for="cf-message">What&rsquo;s eating your team&rsquo;s hours?</label>
    <textarea
      id="cf-message"
      name="message"
      rows="5"
      required
      placeholder="The report that takes every Friday, the data that gets typed twice, the approvals that wait in someone’s inbox…"
    ></textarea>
  </div>

  <!-- Formspree plumbing: spam honeypot + subject + redirect -->
  <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" class="visually-hidden" aria-hidden="true" />
  <input type="hidden" name="_subject" value="Website inquiry — rubiconworkflows.ca" />
  <input type="hidden" name="_next" value="https://rubiconworkflows.ca/contact/thanks/" />

  <div class="contact-form__foot">
    <button class="contact-form__btn" type="submit" disabled={!live}>
      Send the note <span class="arrow" aria-hidden="true">&rarr;</span>
    </button>
    <p class="contact-form__note">Plain words are enough &mdash; we&rsquo;ll ask the right questions.</p>
  </div>
</form>

<style>
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .contact-form__notice {
    margin: 0;
  }

  .contact-form__row {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-8);
  }

  .contact-form__field {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .contact-form__field label {
    display: inline-flex;
    align-items: baseline;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--text-eyebrow);
    line-height: var(--lh-eyebrow);
    letter-spacing: var(--track-eyebrow);
    text-transform: uppercase;
    color: var(--muted);
  }

  .contact-form__field label .opt {
    /* not accent-2: on light that's Slate, which fails AA at this size (CD #10) */
    color: var(--muted);
    text-transform: none;
    letter-spacing: 0.02em;
  }

  .contact-form__field input,
  .contact-form__field textarea {
    width: 100%;
    margin: 0;
    padding: var(--space-3) 0;
    border: 0;
    border-bottom: 1px solid color-mix(in srgb, var(--pine) 30%, transparent);
    border-radius: 0;
    background: linear-gradient(var(--accent), var(--accent)) left bottom / 0% 2px no-repeat;
    font-family: var(--font-sans);
    font-size: var(--text-body-l);
    line-height: var(--lh-body-l);
    color: var(--fg);
    transition:
      background-size 0.45s var(--ease),
      border-color var(--dur-base) var(--ease);
  }

  .contact-form__field textarea {
    resize: vertical;
    min-height: 8.5rem;
  }

  .contact-form__field input::placeholder,
  .contact-form__field textarea::placeholder {
    /* comp's pine-38% mix lands at 2.2:1 on Bone — muted is the AA-safe mix */
    color: var(--muted);
    opacity: 1;
  }

  .contact-form__field input:hover,
  .contact-form__field textarea:hover {
    border-bottom-color: color-mix(in srgb, var(--pine) 55%, transparent);
  }

  /* focus: a Forest rule draws in from the left */
  .contact-form__field input:focus-visible,
  .contact-form__field textarea:focus-visible {
    outline: none;
    background-size: 100% 2px;
  }

  .contact-form__foot {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    flex-wrap: wrap;
    padding-top: var(--space-2);
  }

  .contact-form__btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-8);
    border: 0;
    border-radius: var(--radius-full);
    background: var(--cta-bg); /* forest on bone */
    color: var(--cta-fg);
    font-family: var(--font-sans);
    font-size: var(--text-body-m);
    font-weight: 500;
    letter-spacing: -0.005em;
    cursor: pointer;
    width: fit-content;
    transition: background-color var(--dur-fast) var(--ease);
  }

  .contact-form__btn .arrow {
    font-family: var(--font-mono);
    transition: transform var(--dur-base) var(--ease);
  }

  .contact-form__btn:hover {
    background: color-mix(in srgb, var(--cta-bg) 88%, var(--pine));
  }

  .contact-form__btn:hover .arrow {
    transform: translateX(3px);
  }

  .contact-form__btn:disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }

  .contact-form__note {
    margin: 0;
    font-family: var(--font-mono);
    font-size: var(--text-mono-inline);
    line-height: var(--lh-mono-inline);
    color: var(--muted);
  }

  @media (max-width: 640px) {
    .contact-form__row {
      grid-template-columns: 1fr;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .contact-form__field input,
    .contact-form__field textarea {
      transition: none;
    }
  }
</style>
