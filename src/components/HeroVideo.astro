---
/**
 * Full-bleed looping hero background video — the site's only JS island.
 *
 * DROP-IN CONTRACT (nothing else changes):
 *   video:  public/video/hero.mp4
 *   poster: public/video/hero-poster.jpg   (optional)
 * The file is detected at build time; until it exists, a static Pine
 * treatment renders. Vercel picks the asset up on the next push.
 *
 * Behavior (adapted from the approved hero reference):
 *  - starts at opacity 0; 0.5s rAF fade-in after play starts
 *  - 0.5s fade-out approaching the end
 *  - on ended: opacity 0 → wait 100ms → restart from 0
 *  - prefers-reduced-motion: never plays (poster/static stays)
 *  - opacity caps at 0.5 so Pine dominates and text stays AA over any frame
 */
import fs from 'node:fs';

const hasVideo = fs.existsSync('public/video/hero.mp4');
const hasPoster = fs.existsSync('public/video/hero-poster.jpg');
const poster = hasPoster ? '/video/hero-poster.jpg' : undefined;
---

<div class="hero-media" aria-hidden="true">
  {
    hasVideo ? (
      <video id="hero-video" muted playsinline preload="metadata" poster={poster} src="/video/hero.mp4" />
    ) : (
      poster && <img src={poster} alt="" loading="eager" />
    )
  }
  <div class="hero-media__scrim"></div>
</div>

<script>
  // No-ops harmlessly when the video element isn't rendered (asset missing).
  const video = document.getElementById('hero-video') as HTMLVideoElement | null;

  if (video) {
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)');
    const MAX_OPACITY = 0.5;
    const FADE_S = 0.5;
    let rafId = 0;

    const tick = () => {
      if (video.duration) {
        const t = video.currentTime;
        const fadeIn = Math.min(t / FADE_S, 1);
        const fadeOut = Math.min(Math.max(video.duration - t, 0) / FADE_S, 1);
        video.style.opacity = String(Math.min(fadeIn, fadeOut) * MAX_OPACITY);
      }
      rafId = requestAnimationFrame(tick);
    };

    const stop = () => {
      cancelAnimationFrame(rafId);
      video.pause();
      video.style.opacity = '0';
    };

    const start = () => {
      if (reduced.matches) return;
      video
        .play()
        .then(() => {
          cancelAnimationFrame(rafId);
          rafId = requestAnimationFrame(tick);
        })
        .catch(() => {
          /* autoplay blocked — static treatment stays */
        });
    };

    video.addEventListener('ended', () => {
      video.style.opacity = '0';
      setTimeout(() => {
        video.currentTime = 0;
        start();
      }, 100);
    });

    document.addEventListener('visibilitychange', () => {
      document.hidden ? stop() : start();
    });

    reduced.addEventListener('change', () => {
      reduced.matches ? stop() : start();
    });

    start();
  }
</script>

<style>
  .hero-media {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .hero-media video,
  .hero-media img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-media video {
    opacity: 0;
  }

  .hero-media img {
    opacity: 0.35;
  }

  .hero-media__scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to top, var(--pine) 0%, transparent 30%),
      linear-gradient(to bottom, var(--scrim-pine), var(--scrim-pine));
  }
</style>
