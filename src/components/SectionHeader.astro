---
/**
 * Standard section opener: eyebrow kicker + H2 + optional lede.
 */
import Eyebrow from './Eyebrow.astro';

interface Props {
  eyebrow?: string;
  title: string;
  /** Heading level — keep document outline valid. */
  as?: 'h1' | 'h2' | 'h3';
  lede?: string;
  class?: string;
}

const { eyebrow, title, as: Tag = 'h2', lede, class: className }: Props = Astro.props;
---

<header class:list={['section-header', className]}>
  {eyebrow && <Eyebrow>{eyebrow}</Eyebrow>}
  <Tag class="section-header__title">{title}</Tag>
  {lede && <p class="section-header__lede">{lede}</p>}
</header>

<style>
  .section-header {
    margin-bottom: var(--space-12);
    max-width: 46rem;
  }

  .section-header__title {
    margin-top: var(--space-3);
  }

  .section-header__lede {
    margin-top: var(--space-4);
    font-size: var(--text-body-l);
    line-height: var(--lh-body-l);
    color: var(--muted);
  }
</style>
