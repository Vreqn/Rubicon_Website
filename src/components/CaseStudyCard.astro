---
/**
 * Case-study card, designed for the dark "Our work" canvas.
 */
import Icon from './Icon.astro';

interface Props {
  title: string;
  description: string;
  sector: string;
  href: string;
  /** Heading level — h3 under a section h2 (homepage), h2 under a page h1 (work index). */
  as?: 'h2' | 'h3';
}

const { title, description, sector, href, as: Tag = 'h3' }: Props = Astro.props;
const sectorLabel = sector.replace(/-/g, ' ');
---

<article class="cs-card">
  <p class="cs-card__sector">~ {sectorLabel}</p>
  <Tag class="cs-card__title">
    <a href={href}>{title}</a>
  </Tag>
  <p class="cs-card__desc">{description}</p>
  <span class="cs-card__cta" aria-hidden="true">
    Read the case study <Icon name="arrow-right" size={16} />
  </span>
</article>

<style>
  .cs-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-6);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    transition: border-color var(--dur-base) var(--ease);
  }

  .cs-card:hover {
    border-color: var(--accent);
  }

  .cs-card__sector {
    font-family: var(--font-mono);
    font-size: var(--text-eyebrow);
    line-height: var(--lh-eyebrow);
    letter-spacing: var(--track-eyebrow);
    text-transform: uppercase;
    color: var(--accent);
  }

  .cs-card__title {
    font-size: var(--text-h3);
    line-height: var(--lh-h3);
    letter-spacing: var(--track-h3);
  }

  .cs-card__title a {
    text-decoration: none;
  }

  /* Whole card clickable without nesting interactive elements */
  .cs-card__title a::after {
    content: '';
    position: absolute;
    inset: 0;
  }

  .cs-card__desc {
    color: var(--muted);
    flex: 1;
  }

  .cs-card__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-body-s);
    color: var(--accent);
  }
</style>
