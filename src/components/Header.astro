---
/**
 * Site header — always dark (Pine): consistent chrome on a dark-led brand.
 * Lockup = mark + Space Grotesk text. NOTE: the real wordmark is not
 * finalized (brand v0.2); this text treatment is the labeled placeholder —
 * see Content-Decisions.md #6.
 */
import Logo from './Logo.astro';

const nav = [
  { href: '/about/', label: 'About' },
  { href: '/services/', label: 'Services' },
  { href: '/work/', label: 'Work' },
  { href: '/blog/', label: 'Blog' },
  { href: '/contact/', label: 'Contact' },
];

const current = Astro.url.pathname;
const isActive = (href: string) => current === href || (href !== '/' && current.startsWith(href));
---

<header data-surface="dark" class="site-header">
  <div class="container site-header__inner">
    <a href="/" class="site-header__brand" aria-label="Rubicon Workflows — home">
      <Logo size={34} />
      <span class="site-header__name">Rubicon Workflows</span>
    </a>

    <button
      class="site-header__toggle"
      type="button"
      aria-expanded="false"
      aria-controls="site-nav"
    >
      <span class="visually-hidden">Menu</span>
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <path class="icon-open" d="M3 6h18M3 12h18M3 18h18" />
        <path class="icon-close" d="M5 5l14 14M19 5L5 19" style="display: none" />
      </svg>
    </button>

    <nav id="site-nav" class="site-header__nav" aria-label="Main">
      <ul>
        {nav.map(({ href, label }) => (
          <li>
            <a href={href} aria-current={isActive(href) ? 'page' : undefined}>{label}</a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
  <div class="site-header__rule" aria-hidden="true"></div>
</header>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('.site-header__toggle');
  const nav = document.getElementById('site-nav');
  toggle?.addEventListener('click', () => {
    const open = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!open));
    nav?.classList.toggle('is-open', !open);
    toggle.querySelector<SVGPathElement>('.icon-open')!.style.display = open ? '' : 'none';
    toggle.querySelector<SVGPathElement>('.icon-close')!.style.display = open ? 'none' : '';
  });
</script>

<style>
  .site-header {
    position: relative;
    z-index: var(--z-header);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
    padding-block: var(--space-4);
  }

  .site-header__brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    text-decoration: none;
  }

  .site-header__brand:hover {
    color: var(--fg);
  }

  .site-header__name {
    font-weight: 500;
    font-size: var(--text-body-l);
    letter-spacing: var(--track-h3);
    white-space: nowrap;
  }

  .site-header__rule {
    height: 1px;
    background: linear-gradient(to right, transparent, var(--line), transparent);
  }

  .site-header__nav ul {
    display: flex;
    gap: var(--space-6);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .site-header__nav a {
    text-decoration: none;
    color: var(--muted);
    transition: color var(--dur-fast) var(--ease);
  }

  .site-header__nav a:hover {
    color: var(--fg);
  }

  .site-header__nav a[aria-current='page'] {
    color: var(--accent);
  }

  .site-header__toggle {
    display: none;
    background: none;
    border: none;
    color: var(--fg);
    padding: var(--space-2);
    cursor: pointer;
  }

  @media (max-width: 767.98px) {
    .site-header__toggle {
      display: inline-flex;
    }

    .site-header__nav {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background-color: var(--bg);
      border-bottom: 1px solid var(--line);
    }

    .site-header__nav.is-open {
      display: block;
    }

    .site-header__nav ul {
      flex-direction: column;
      gap: 0;
      padding: var(--space-2) var(--container-pad) var(--space-4);
    }

    .site-header__nav a {
      display: block;
      padding: var(--space-3) 0;
      font-size: var(--text-body-l);
    }
  }
</style>
