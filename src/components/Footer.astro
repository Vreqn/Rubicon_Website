---
/**
 * Site footer — dark, with the brand-signature tilde flourish.
 * Public contact email is undecided — Content-Decisions.md #2.
 */
import Todo from './Todo.astro';

const year = new Date().getFullYear();

const nav = [
  { href: '/services/', label: 'Services' },
  { href: '/work/', label: 'Case Studies' },
  { href: '/about/', label: 'About' },
  { href: '/contact/', label: 'Contact' },
  // Blog hidden for now — pages still build; re-add when ready.
];
---

<footer data-surface="dark" class="site-footer">
  <div class="container">
    <div class="site-footer__flourish" aria-hidden="true">~</div>

    <div class="site-footer__cols">
      <div>
        <p class="site-footer__name">Rubicon Workflows</p>
        <p class="site-footer__tagline">Automate the routine, focus on the results.</p>
      </div>

      <nav aria-label="Footer">
        <ul>
          {nav.map(({ href, label }) => (
            <li><a href={href}>{label}</a></li>
          ))}
        </ul>
      </nav>

      <div class="site-footer__contact">
        <p class="site-footer__mono">@rubiconworkflows</p>
        <p><Todo label="public contact email" /></p>
      </div>
    </div>

    <p class="site-footer__legal">&copy; {year} Rubicon Workflows &middot; Vancouver, BC</p>
  </div>
</footer>

<style>
  .site-footer {
    padding-block: var(--space-12) var(--space-8);
    border-top: 1px solid var(--line);
  }

  .site-footer__flourish {
    font-family: var(--font-mono);
    color: var(--accent);
    font-size: var(--text-h2);
    margin-bottom: var(--space-8);
  }

  .site-footer__cols {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-12);
    justify-content: space-between;
  }

  .site-footer__name {
    font-weight: 500;
  }

  .site-footer__tagline {
    color: var(--muted);
    margin-top: var(--space-1);
    font-size: var(--text-body-s);
    line-height: var(--lh-body-s);
  }

  .site-footer nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4) var(--space-6);
  }

  .site-footer nav a {
    text-decoration: none;
    color: var(--muted);
  }

  .site-footer nav a:hover {
    color: var(--fg);
  }

  .site-footer__contact {
    text-align: right;
  }

  .site-footer__mono {
    font-family: var(--font-mono);
    font-size: var(--text-mono-inline);
    color: var(--accent-2);
  }

  .site-footer__legal {
    margin-top: var(--space-12);
    font-size: var(--text-caption);
    line-height: var(--lh-caption);
    color: var(--muted);
  }

  @media (max-width: 767.98px) {
    .site-footer__cols {
      flex-direction: column;
      gap: var(--space-8);
    }

    .site-footer__contact {
      text-align: left;
    }
  }
</style>
