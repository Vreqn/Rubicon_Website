---
/**
 * Site footer — dark, with the brand-signature tilde flourish.
 * 2026-06 design port: brand blurb + Sitemap / Connect columns.
 * Email stays krisztian@ (Content-Decisions #2 — the comps' hello@ is an
 * owner option, not resolved). The @handle has no real URL yet, so it
 * renders as text, never a dead link.
 */
const year = new Date().getFullYear();
const email = 'krisztian@rubiconworkflows.ca';

const nav = [
  { href: '/services/', label: 'Services' },
  { href: '/work/', label: 'Work' },
  { href: '/about/', label: 'About' },
  { href: '/contact/', label: 'Contact' },
  // Blog hidden for now — pages still build; re-add when ready.
];
---

<footer data-surface="dark" class="site-footer">
  <div class="site-footer__inner">
    <div class="site-footer__brand">
      <span class="site-footer__tilde" aria-hidden="true">~</span>
      <p>
        Rubicon Workflows &mdash; automation consultancy, Vancouver BC. We find the manual work
        eating your hours and automate it, one bottleneck at a time.
      </p>
    </div>

    <div class="site-footer__cols">
      <nav class="site-footer__col" aria-label="Footer">
        <span class="site-footer__head">Sitemap</span>
        {nav.map(({ href, label }) => <a href={href}>{label}</a>)}
      </nav>
      <div class="site-footer__col">
        <span class="site-footer__head">Connect</span>
        <a href={`mailto:${email}`}>{email}</a>
        <span class="site-footer__handle">@rubiconworkflows</span>
      </div>
    </div>
  </div>
  <p class="site-footer__legal">&copy; {year} Rubicon Workflows &middot; Vancouver, BC</p>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--line);
    padding: var(--space-16) 0 var(--space-8);
  }

  .site-footer__inner {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--container-pad);
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-12);
    flex-wrap: wrap;
  }

  .site-footer__brand {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    max-width: 22rem;
  }

  .site-footer__tilde {
    font-family: var(--font-mono);
    font-size: var(--text-h1);
    line-height: 1;
    color: var(--accent-text);
  }

  .site-footer__brand p {
    margin: 0;
    font-size: var(--text-body-s);
    line-height: var(--lh-body-s);
    color: var(--muted);
  }

  .site-footer__cols {
    display: flex;
    gap: var(--space-24);
    flex-wrap: wrap;
  }

  .site-footer__col {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .site-footer__head {
    font-family: var(--font-mono);
    font-size: var(--text-eyebrow);
    letter-spacing: var(--track-eyebrow);
    text-transform: uppercase;
    color: var(--accent-2);
    margin-bottom: var(--space-1);
  }

  .site-footer__col a {
    font-size: var(--text-body-s);
    color: var(--fg);
    text-decoration: none;
    opacity: 0.82;
    transition:
      color var(--dur-fast) var(--ease),
      opacity var(--dur-fast) var(--ease);
  }

  .site-footer__col a:hover {
    color: var(--accent-text);
    opacity: 1;
  }

  .site-footer__handle {
    font-size: var(--text-body-s);
    color: var(--muted);
  }

  .site-footer__legal {
    max-width: var(--container-max);
    margin: var(--space-12) auto 0;
    padding: 0 var(--container-pad);
    font-size: var(--text-caption);
    line-height: var(--lh-caption);
    color: var(--muted);
  }

  @media (max-width: 767.98px) {
    .site-footer__cols {
      gap: var(--space-12);
    }
  }
</style>
