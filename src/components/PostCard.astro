---
/**
 * Blog index card — light surface.
 */
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  href: string;
  /** Heading level — keep the page outline valid (h2 under both page h1s and section h2s). */
  as?: 'h2' | 'h3';
}

const { title, description, pubDate, href, as: Tag = 'h2' }: Props = Astro.props;

const dateLabel = pubDate.toLocaleDateString('en-CA', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="post-card">
  <p class="post-card__date">
    <time datetime={pubDate.toISOString().slice(0, 10)}>{dateLabel}</time>
  </p>
  <Tag class="post-card__title">
    <a href={href}>{title}</a>
  </Tag>
  <p class="post-card__desc">{description}</p>
</article>

<style>
  .post-card {
    position: relative;
    padding-block: var(--space-6);
    border-bottom: 1px solid var(--line);
  }

  .post-card__date {
    font-family: var(--font-mono);
    font-size: var(--text-mono-inline);
    line-height: var(--lh-mono-inline);
    color: var(--muted);
  }

  .post-card__title {
    margin-top: var(--space-2);
    font-size: var(--text-h3);
    line-height: var(--lh-h3);
    letter-spacing: var(--track-h3);
  }

  .post-card__title a {
    text-decoration: none;
  }

  .post-card__title a:hover {
    color: var(--accent);
  }

  .post-card__title a::after {
    content: '';
    position: absolute;
    inset: 0;
  }

  .post-card__desc {
    margin-top: var(--space-2);
    color: var(--muted);
    max-width: var(--container-prose);
  }
</style>
