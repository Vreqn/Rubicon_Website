---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import BgVideo from '../components/BgVideo.astro';
import PillarsTicker from '../components/PillarsTicker.astro';
import PillarFlow from '../components/PillarFlow.astro';
import StudyCard from '../components/StudyCard.astro';
import CtaBand from '../components/CtaBand.astro';
// LogoMarquee is BUILT but not rendered — no real client logos exist yet
// (Content-Decisions #5). When logos land: import it and swap it into the
// post-hero strip below in place of PillarsTicker.

const caseStudies = (await getCollection('work', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': 'https://rubiconworkflows.ca/#org',
  name: 'Rubicon Workflows',
  description:
    'Custom workflow automation for small and mid-sized businesses. Vancouver, BC.',
  url: 'https://rubiconworkflows.ca/',
  logo: 'https://rubiconworkflows.ca/favicon-32.png',
  email: 'krisztian@rubiconworkflows.ca',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Vancouver',
    addressRegion: 'BC',
    addressCountry: 'CA',
  },
  areaServed: 'Vancouver, BC',
  knowsAbout: ['workflow automation', 'business process automation', 'systems integration'],
};
---

<BaseLayout
  title="Rubicon Workflows | Custom Automation for Vancouver Businesses"
  description="We find the parts of your operation that are eating your team's time and automate them — inside the systems you already use. Vancouver, BC."
  surface="dark"
  headerOverlay
  jsonLd={jsonLd}
>
  <!-- Hero — full-viewport footage, immersive scrim, centered copy hanging
       high in the "sky" of the frame. The scrim carries AA at data-max 1. -->
  <section data-surface="dark" class="hero">
    <BgVideo src="/video/hero.mp4" poster="/video/hero-poster.jpg" maxOpacity={1} />
    <div class="hero__scrim" aria-hidden="true"></div>
    <div class="hero__inner">
      <div class="hero__copy">
        <h1 class="hero__tagline">
          <span>Automate the routine.</span>
          <span class="l2">Focus on the results.</span>
        </h1>
        <p class="hero__lede">
          We find the parts of your operation that are eating your team&rsquo;s time, and we
          automate them &mdash; increasing accuracy and freeing people up for the work that
          actually matters, without replacing your systems or overhauling how you work.
        </p>
      </div>
    </div>
  </section>

  <!-- Post-hero strip — seamless Pine continuation. PillarsTicker stays live
       until real client logos exist, then LogoMarquee takes this slot. -->
  <section data-surface="dark" class="ticker-section">
    <div class="container">
      <PillarsTicker />
    </div>
  </section>

  <!-- Four-pillar pipeline — "one bottleneck at a time" -->
  <section data-surface="dark" class="section pillars" id="services">
    <div class="container">
      <div class="shead" data-reveal>
        <h2>We automate one bottleneck at a time.</h2>
        <p class="shead__lede">
          No big-bang transformation. We find the highest-friction task, automate it cleanly,
          and move to the next &mdash; so the work keeps running the whole way through.
        </p>
      </div>
      <PillarFlow />
    </div>
  </section>

  <!-- Selected work — ambient glow footage under a Pine scrim -->
  <section data-surface="dark" class="section work" id="work">
    <BgVideo src="/video/glow.mp4" maxOpacity={1} lazy class="work__video" />
    <div class="work__scrim" aria-hidden="true"></div>
    <div class="container work__inner">
      <div class="shead" data-reveal>
        <h2>Proof, not promises.</h2>
      </div>
      <div class="studies" data-tilt-grid>
        {
          caseStudies.map((cs, i) => (
            <StudyCard
              title={cs.data.title}
              summary={cs.data.summary}
              sector={cs.data.sector}
              metric={cs.data.metric}
              tint={cs.data.tint}
              href={`/work/#${cs.id}`}
              sample={cs.data.sample}
              revealDelay={60 + i * 80}
            />
          ))
        }
      </div>
      <a class="work__all" href="/work/">See all the work <span class="arrow" aria-hidden="true">&rarr;</span></a>
    </div>
  </section>

  <!-- Forest CTA band — the one signature-surface moment on this page -->
  <CtaBand
    id="cta"
    title="Tell us what’s eating your team’s time."
    lede="One conversation. We’ll point to the task worth automating first — no pitch, no commitment."
    ctaLabel="Start the conversation"
    ctaHref="/contact/"
  />
</BaseLayout>

<script>
  import '../scripts/tilt.js';
</script>

<style>
  /* ---- Hero ---- */
  .hero {
    position: relative;
    min-height: 640px;
    height: 100vh;
    overflow: hidden;
    isolation: isolate;
  }

  /* Immersive scrim (the approved atmosphere) — thinner at the edges so the
     footage reads brighter; resolves to solid Pine at the bottom so the hero
     fades seamlessly into the ticker strip. AA over footage rides on this:
     the radial center is heavier than the comp's 48% because the muted
     second tagline line failed 3:1 against the brightest frames
     (scripts/video-aa-check.mjs) — thicken-the-scrim is the brand remedy,
     never text over raw footage. */
  .hero__scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background:
      radial-gradient(
        130% 100% at 50% 32%,
        color-mix(in srgb, var(--bg) 86%, transparent) 0%,
        color-mix(in srgb, var(--bg) 82%, transparent) 45%,
        transparent 68%
      ),
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--bg) 40%, transparent) 0%,
        color-mix(in srgb, var(--bg) 8%, transparent) 36%,
        color-mix(in srgb, var(--bg) 6%, transparent) 58%,
        color-mix(in srgb, var(--bg) 46%, transparent) 84%,
        var(--bg) 100%
      );
  }

  .hero__inner {
    position: relative;
    z-index: 2;
    height: 100%;
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--container-pad);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  /* The copy hangs high in the frame, clearing the video horizon.
     (Comp said 35.5rem "matches the headline's rendered width" — but its
     capture used fallback fonts; real Space Grotesk at Display XL needs
     ~38.5rem for "Automate the routine." to hold one line.) */
  .hero__copy {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-6);
    max-width: 38.5rem;
    padding-top: clamp(4.25rem, 13vh, 7.75rem);
  }

  .hero__tagline {
    margin: 0;
    font-weight: 500;
    font-size: var(--text-display-xl);
    line-height: var(--lh-display-xl);
    letter-spacing: var(--track-display-xl);
    color: var(--fg);
  }

  .hero__tagline span {
    display: block;
  }

  .hero__tagline .l2 {
    color: var(--muted);
  }

  .hero__lede {
    margin: 0;
    width: 100%;
    font-size: var(--text-body-l);
    line-height: var(--lh-body-l);
    letter-spacing: 0.005em;
    color: var(--muted);
    text-wrap: pretty;
  }

  @media (max-width: 768px) {
    .hero__copy {
      max-width: none;
      padding-top: clamp(5rem, 16vh, 8rem);
      gap: var(--space-8);
    }
  }

  /* ---- Ticker strip ---- */
  .ticker-section {
    position: relative;
    z-index: 2;
    padding-block: var(--space-8) var(--space-12);
  }

  /* ---- Shared section scaffolding ---- */
  .section {
    position: relative;
    padding-block: var(--section-pad);
  }

  .shead {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    max-width: 40rem;
    margin-bottom: var(--space-16);
  }

  .shead h2 {
    margin: 0;
    font-weight: 500;
    font-size: var(--text-display-l);
    line-height: var(--lh-display-l);
    letter-spacing: var(--track-display-l);
    color: var(--fg);
    text-wrap: balance;
  }

  .shead__lede {
    margin: 0;
    font-size: var(--text-body-l);
    line-height: var(--lh-body-l);
    color: var(--muted);
    text-wrap: pretty;
  }

  /* ---- Selected work ---- */
  .work {
    overflow: hidden;
    isolation: isolate;
  }

  .work .shead {
    margin-bottom: var(--space-12);
  }

  .work__inner {
    position: relative;
    z-index: 2;
  }

  /* Footage sits under a Pine scrim so the studies + copy stay fully legible. */
  .work__scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background:
      radial-gradient(
        120% 90% at 50% 38%,
        color-mix(in srgb, var(--bg) 58%, transparent) 0%,
        color-mix(in srgb, var(--bg) 80%, transparent) 60%,
        var(--bg) 100%
      ),
      linear-gradient(
        180deg,
        var(--bg) 0%,
        color-mix(in srgb, var(--bg) 62%, transparent) 22%,
        color-mix(in srgb, var(--bg) 62%, transparent) 78%,
        var(--bg) 100%
      );
  }

  .studies {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }

  .studies[data-tilt='on'] {
    perspective: 1200px;
  }

  .work__all {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin-top: var(--space-12);
    font-size: var(--text-body-m);
    font-weight: 500;
    color: var(--accent-text);
    text-decoration: none;
    width: fit-content;
  }

  .work__all .arrow {
    font-family: var(--font-mono);
    transition: transform var(--dur-base) var(--ease);
  }

  .work__all:hover .arrow {
    transform: translateX(3px);
  }

  @media (max-width: 768px) {
    .studies {
      grid-template-columns: 1fr;
    }
  }
</style>
