---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import Eyebrow from '../components/Eyebrow.astro';
import Icon from '../components/Icon.astro';
import Button from '../components/Button.astro';

// Capability areas confirmed by Krisztian 2026-06-10 (Content-Decisions #1,
// resolved): no packages, no pricing — plain-language areas of work.
const capabilities = [
  {
    icon: 'chart',
    title: 'Automated reporting',
    body: 'The weekly report that eats someone’s morning builds and sends itself — same numbers, same format, on time, every time.',
  },
  {
    icon: 'nodes',
    title: 'Connecting systems',
    body: 'When two tools don’t talk, somebody becomes the messenger. We build the connection so data moves on its own, accurately, in both directions.',
  },
  {
    icon: 'intake',
    title: 'Data entry automation',
    body: 'Information gets captured once, where it first shows up, and lands everywhere it needs to be. No retyping, no copy-paste mistakes.',
  },
  {
    icon: 'document',
    title: 'Document processing',
    body: 'Extracting, comparing, and organizing the documents your team works through by hand — quotes, invoices, the paperwork that piles up.',
  },
  {
    icon: 'check-circle',
    title: 'Verification & summarization tools',
    body: 'Tools that double-check human work — validation steps that catch errors before they cost money — and tools that summarize long documentation so people can act on it. Where that uses AI, we say so plainly.',
  },
] as const;

// Pillar copy verbatim from Brand Guidelines §1.
const approach = [
  {
    icon: 'gauge',
    title: 'Operational efficiency',
    body: 'Smoother operations, real cost savings.',
  },
  {
    icon: 'shield-check',
    title: 'Error reduction',
    body: 'Fewer mistakes through code-based consistency or human-in-the-loop validation.',
  },
  {
    icon: 'steps',
    title: 'Incremental and embedded',
    body: 'We work within your existing infrastructure, starting with one step and compounding wins from there. No rip-and-replace, no platform lock-in.',
  },
  {
    icon: 'user-plus',
    title: 'Augmentation, not replacement',
    body: 'We automate the tedious parts so people can focus on the work they actually care about.',
  },
] as const;
---

<BaseLayout
  title="Rubicon Workflows | Automation Services for Vancouver Businesses"
  description="Custom workflow automation built inside the systems you already use — starting with one bottleneck. Plain-language services from a Vancouver consultancy."
  surface="light"
>
  <!-- Dark intro -->
  <Section surface="dark">
    <header class="services-hero">
      <Eyebrow>Services</Eyebrow>
      <h1 class="services-hero__title">We automate the parts that eat your team's time.</h1>
      <p class="services-hero__lede">
        Weekly reports, data entry, the back-and-forth between systems that don't talk to
        each other. We find the bottleneck, automate that one step inside the tools you
        already use, and build from there.
      </p>
    </header>
  </Section>

  <!-- Light body -->
  <Section surface="light">
    <div class="services-body">
      <h2>How we approach every engagement</h2>
      <ul class="approach">
        {
          approach.map(({ icon, title, body }) => (
            <li class="approach__item">
              <Icon name={icon} feature size={24} />
              <div>
                <h3>{title}</h3>
                <p>{body}</p>
              </div>
            </li>
          ))
        }
      </ul>

      <h2>What we build</h2>
      <ul class="capabilities">
        {
          capabilities.map(({ icon, title, body }) => (
            <li class="capability">
              <Icon name={icon} feature size={24} />
              <div>
                <h3>{title}</h3>
                <p>{body}</p>
              </div>
            </li>
          ))
        }
      </ul>
      <p class="capabilities-note">
        Every engagement is scoped individually — we start with the one bottleneck that's
        costing you the most, not a package.
      </p>

      <div class="services-cta">
        <p>
          Not sure whether your bottleneck is automatable? That's a normal place to start —
          most of our conversations begin there.
        </p>
        <Button variant="primary" href="/contact/">Tell us what's eating your time</Button>
      </div>
    </div>
  </Section>
</BaseLayout>

<style>
  .services-hero {
    max-width: 46rem;
  }

  .services-hero__title {
    margin-top: var(--space-3);
    font-size: var(--text-display-l);
    line-height: var(--lh-display-l);
    letter-spacing: var(--track-display-l);
  }

  .services-hero__lede {
    margin-top: var(--space-6);
    font-size: var(--text-body-l);
    line-height: var(--lh-body-l);
    color: var(--muted);
  }

  .services-body h2 {
    margin-bottom: var(--space-8);
  }

  .services-body h2 + .approach {
    margin-bottom: var(--space-16);
  }

  .capabilities {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(20rem, 1fr));
    gap: var(--space-8);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .capability {
    display: flex;
    gap: var(--space-4);
    align-items: flex-start;
  }

  .capability p {
    margin-top: var(--space-2);
    color: var(--muted);
  }

  .capabilities-note {
    margin-block: var(--space-8) var(--space-16);
    font-size: var(--text-body-s);
    line-height: var(--lh-body-s);
    color: var(--muted);
    max-width: 38rem;
  }

  @media (max-width: 767.98px) {
    .capabilities {
      grid-template-columns: 1fr;
    }
  }

  .approach {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(20rem, 1fr));
    gap: var(--space-8);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .approach__item {
    display: flex;
    gap: var(--space-4);
    align-items: flex-start;
  }

  .approach__item p {
    margin-top: var(--space-2);
    color: var(--muted);
  }

  .services-cta {
    border-top: 1px solid var(--line);
    padding-top: var(--space-12);
    max-width: 38rem;
  }

  .services-cta p {
    margin-bottom: var(--space-6);
    font-size: var(--text-body-l);
    line-height: var(--lh-body-l);
  }

  @media (max-width: 767.98px) {
    .approach {
      grid-template-columns: 1fr;
    }
  }
</style>
