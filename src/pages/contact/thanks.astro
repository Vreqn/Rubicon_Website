---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/Button.astro';
---

<BaseLayout
  title="Rubicon Workflows | Message Received"
  description="Thanks for reaching out to Rubicon Workflows. We'll get back to you soon."
  surface="dark"
  noindex
>
  <section data-surface="dark" class="thanks-section">
    <div class="container">
      <div class="thanks" role="status">
        <span class="thanks__tilde" aria-hidden="true">~</span>
        <h1 class="thanks__title">Got it. We&rsquo;ll be in touch.</h1>
        <p class="thanks__body">
          Your note lands with both of us, and the reply comes from one of us &mdash; not a
          sequence. If it&rsquo;s quicker, just answer the email when it arrives.
        </p>
        <Button variant="secondary" href="/">Back to the homepage</Button>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .thanks-section {
    padding-block: var(--section-pad);
  }

  .thanks {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-4);
    max-width: 38rem;
    margin: 0 auto;
    padding: var(--space-16) var(--space-8);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
  }

  .thanks__tilde {
    font-family: var(--font-mono);
    font-size: var(--text-display-l);
    line-height: 1;
    color: var(--accent-text);
  }

  .thanks__title {
    margin: 0;
    font-size: var(--text-h1);
    line-height: var(--lh-h1);
    letter-spacing: var(--track-h1);
  }

  .thanks__body {
    margin: 0 0 var(--space-4);
    max-width: 34rem;
    color: var(--muted);
  }
</style>
